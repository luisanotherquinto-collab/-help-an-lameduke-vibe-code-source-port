    fall
    ifaction WOODENHORSEFRAME ifhitweapon
    {
        spawn EXPLOSION

        ifwasweapon RPG
            killit
        else action WOODENFALLFRAME
    }
enda

action PARKINGMETERFRAME    0   1   2
actor PARKINGMETER WEAKEST PARKINGMETERFRAME
    ifhitweapon cactor PARKINGMETERDEAD
enda

actor DUDPIPE4 WEAKEST
    ifhitweapon cactor DUDPIPE4HIT
enda

